# Créer le fichier .gitignore
cat > .gitignore << 'EOF'
# Dependencies
node_modules/
package-lock.json

# Environment variables
.env
.env.local
.env.production

# Build files
dist/
build/
*.log

# IDE
.vscode/
.idea/
*.swp
*.swo
*~

# Docker
Dockerfile*
docker-compose*.yml
!docker-compose.yml
.dockerignore

# OS
.DS_Store
Thumbs.db
EOF

# Ajouter le .gitignore
git add .gitignore
git commit -m "Add .gitignore"